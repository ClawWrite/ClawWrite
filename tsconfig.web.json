{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "@renderer/*": ["src/renderer/*"] }
  },
  "include": [
    "src/renderer/**/*",
    "src/main/gemini.ts",
    "src/main/settings.ts"
  ]
}
